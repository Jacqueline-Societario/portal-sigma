# .env.example — Portal Societário Sigma
# Copiar para .env e preencher com valores reais.
# NUNCA commitar o .env real.
# Este arquivo so contem exemplos com placeholders — sem credencial real.

# -------------------------------------------------------
# Servidor Flask
# -------------------------------------------------------
PORT=5080
SECRET_KEY=gere-uma-chave-longa-e-aleatoria-aqui

# -------------------------------------------------------
# Inteligencia Artificial
# -------------------------------------------------------
OPENAI_API_KEY=sk-sua-chave-openai-aqui
ANTHROPIC_API_KEY=sua-chave-anthropic-aqui

# -------------------------------------------------------
# Webhook de formularios externos
# -------------------------------------------------------
FORMS_WEBHOOK_TOKEN=seu-token-webhook-aqui

# -------------------------------------------------------
# Seguranca e autenticacao
# -------------------------------------------------------
# Nivel de seguranca: 1=baixo, 2=medio (padrao), 3=alto
SECURITY_LEVEL=2

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=societario.gsigma.com.br
WEBAUTHN_ORIGIN=https://societario.gsigma.com.br

# Dispositivos confiaveis para admin (em dias)
ADMIN_TRUSTED_DEVICE_DAYS=15
ADMIN_STEP_UP_TTL_MINUTES=15
ADMIN_REQUIRE_PASSKEY_EVERY_LOGIN=false
ADMIN_REQUIRE_PASSKEY_FOR_SENSITIVE_ACTIONS=true

# Dispositivos confiaveis para usuarios comuns (em dias)
TRUSTED_DEVICE_DAYS=30
STEP_UP_TTL_MINUTES=15

# -------------------------------------------------------
# Gmail (verificacao de email recebido)
# -------------------------------------------------------
# Caminho para o token OAuth do Gmail (nao versionar o token em si)
GMAIL_TOKEN_PATH=credentials/gmail_token.json
